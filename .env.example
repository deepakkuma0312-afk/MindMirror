# -----------------------------------------------------------------------------
# MindMirror — Environment Variables Example Configuration
# Copy this file to '.env' or '.env.local' to configure your environment.
# Note: Leaving these values empty will run the app in Local Offline Mode,
# which uses an automatic local JSON database (data/mock_db.json).
# -----------------------------------------------------------------------------

# 1. Database Connection (Postgres/Supabase)
# Needed if you want to run Drizzle migrations or write to a live database
DATABASE_URL=postgres://postgres:password@db.supabase.co:5432/postgres

# 2. Supabase Authentication & Client SSR Configuration
# Required for live Supabase Auth sessions and security policies
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 3. AI Providers
# Gemini API Key (Recommended) for streaming empathetic conversations and insights
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API Key (Alternative)
OPENAI_API_KEY=your-openai-api-key

# 4. Security & Cryptography
# 32-character encryption key for AES-256-CBC journal note encryption at rest
ENCRYPTION_KEY=mindmirror-super-secret-key-32b-length-str
