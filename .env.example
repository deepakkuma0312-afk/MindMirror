# -----------------------------------------------------------------------------
# MindMirror — Environment Variables Example Configuration
# Copy this file to '.env' or '.env.local' to configure your environment.
# Note: Leaving these values empty will run the app in Local Offline Mode,
# which uses an automatic local JSON database (data/mock_db.json).
# -----------------------------------------------------------------------------

# 1. Appwrite Configuration
# Required for live Appwrite Auth sessions and Database collections
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_DATABASE_ID=your-appwrite-database-id
APPWRITE_API_KEY=your-appwrite-api-key-with-users-and-databases-scopes
APPWRITE_USERS_TABLE_ID=your-users-table-id
APPWRITE_MOOD_ENTRIES_TABLE_ID=your-mood-entries-table-id
APPWRITE_AI_CONVERSATIONS_TABLE_ID=your-ai-conversations-table-id
APPWRITE_ASSESSMENTS_TABLE_ID=your-assessments-table-id
APPWRITE_INSIGHTS_TABLE_ID=your-insights-table-id
APPWRITE_ALERTS_TABLE_ID=your-alerts-table-id
APPWRITE_THERAPIST_LINKS_TABLE_ID=your-therapist-links-table-id

# 2. AI Providers
# Gemini API Key (Recommended) for streaming empathetic conversations and insights
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API Key (Alternative)
OPENAI_API_KEY=your-openai-api-key

# 3. Security & Cryptography
# 32-character encryption key for AES-256-CBC journal note encryption at rest
ENCRYPTION_KEY=mindmirror-super-secret-key-32b-length-str
